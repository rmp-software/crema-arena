# Database — for local dev, start the Postgres container with `docker compose up -d`
# (defaults match this URL). Prod URL belongs in Vercel env vars, never in .env.
DATABASE_URL="postgresql://crema:crema_dev@localhost:5432/crema_arena?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Admin User (created on seed)
ADMIN_EMAIL="admin@crema-arena.com"
ADMIN_PASSWORD="admin123"
